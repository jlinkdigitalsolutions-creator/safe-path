NODE_ENV=development
PORT=4000
# Create DB, copy this to .env, then: npm run db:migrate && npm run db:seed
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safepath
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGIN=http://localhost:3000
