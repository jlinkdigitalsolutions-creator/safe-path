{
  "name": "safepath-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run db:migrate && tsc",
    "start": "node dist/index.js",
    "db:migrate": "sequelize-cli db:migrate --config config/database.cjs",
    "db:migrate:undo": "sequelize-cli db:migrate:undo --config config/database.cjs",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all --config config/database.cjs",
    "db:seed": "tsx src/database/seed.ts",
    "lint": "eslint src --ext .ts",
    "render-build": "npm run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.7.4",
    "sequelize-cli": "^6.6.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}